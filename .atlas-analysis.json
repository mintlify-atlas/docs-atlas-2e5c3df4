  "keyFeatures": [
    "Tony Stark mentor agent — Senior Architect persona with Colombian coastal personality and 15+ years of simulated experience",
    "Spec-Driven Development (SDD) workflow — structured 9-phase pipeline from exploration to archive",
    "SDD Orchestrator — coordinates sub-agents without doing inline work, enforces delegation rules",
    "Background Agents plugin — async parallel sub-agent delegation with disk-persisted results",
    "Engram persistent memory — cross-session memory via local MCP server backed by SQLite",
    "Auto-loading skills — context-triggered skill injection (go-testing, branch-pr, judgment-day, etc.)",
    "MCP integrations — context7 (library docs), Engram (memory), Chrome DevTools",
    "Skill registry — build-time compact rules resolved once, injected into every sub-agent prompt",
    "Strict TDD mode — auto-detected per project, forwarded to apply/verify phases"
  ],
